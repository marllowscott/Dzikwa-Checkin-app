SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
JWT_SECRET=replace-with-a-strong-secret
PORT=3001

# Notes:
# - Use the Supabase service_role key only on the server. Do NOT publish it in client-side code.
# - Create a table `admins` with columns: id (uuid or int), name (text), email (text, unique), password (text).
# Supabase Configuration
# Get these values from your Supabase project settings at https://supabase.com/dashboard
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here